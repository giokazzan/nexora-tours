{
  "version": 2,
  "builds": [
    {
      "src": "api/checkout.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/checkout",
      "dest": "/api/checkout.js"
    },
    {
      "src": "/(.*\\.(jpeg|jpg|png|gif|webp))",
      "dest": "/public/$1"
    },
    {
      "src": "/index-es.html",
      "dest": "/index-es.html"
    },
    {
      "src": "/index-en.html",
      "dest": "/index-en.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}